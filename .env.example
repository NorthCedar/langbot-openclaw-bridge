# .env.example - Copy to .env and fill in values

# Bridge
BRIDGE_PORT=8780
BRIDGE_TIMEOUT_MS=90000
BRIDGE_MAX_CONCURRENCY=5
BRIDGE_LOG_DIR=./logs

# GeWeChat
GEWECHAT_BASE_URL=http://127.0.0.1:2531
GEWECHAT_TOKEN=your-gewe-token-here
GEWECHAT_APP_ID=your-app-id-here

# Bot identity
BOT_WXID=wxid_your_bot_wxid

# Trigger
BRIDGE_TRIGGER_MODE=at
# BRIDGE_TRIGGER_KEYWORD=鸡腿
# BRIDGE_GROUP_WHITELIST=wxid_group1@chatroom,wxid_group2@chatroom
