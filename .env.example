# .env.example — 复制为 .env 并填入实际值
# cp .env.example .env

# Bridge 监听端口
BRIDGE_PORT=8780

# LangBot 请求验证 token（留空则不校验）
BRIDGE_AUTH_TOKEN=

# 允许的来源 IP（逗号分隔，留空则不限制）
BRIDGE_ALLOWED_IPS=

# openclaw agent CLI 超时（毫秒）
BRIDGE_TIMEOUT_MS=90000

# 最大并发请求数
BRIDGE_MAX_CONCURRENCY=5

# 日志目录
BRIDGE_LOG_DIR=./logs
